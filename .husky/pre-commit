#!/usr/bin/env sh

# husky pre-commit can be executed in environments where npm is not on PATH.
# Provide a clear fallback and avoid blocking users during git commit when tooling is unavailable.
if ! command -v npm >/dev/null 2>&1; then
  echo "[husky] npm not found in PATH. Skipping pre-commit linters."
  echo "Install Node.js and npm, or run 'npm install' before committing."
  exit 0
fi

npm run format && npm run lint
